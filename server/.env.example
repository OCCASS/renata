# Copy to .env and fill in real values. Never commit .env.

# Telegram bot — create via @BotFather, copy the token.
TELEGRAM_BOT_TOKEN=123456:replace-with-real-token

# Chat to deliver leads into. Personal chat: send any message to the bot,
# then open https://api.telegram.org/bot<TOKEN>/getUpdates and copy "id".
# For a group/channel, add the bot as admin first and use the negative id.
TELEGRAM_CHAT_ID=000000000

# Optional outbound proxy for Telegram API. Useful when the server is in
# a region where api.telegram.org is blocked. Leave empty to connect direct.
# Examples:
#   socks5://user:pass@1.2.3.4:1080
#   socks5://1.2.3.4:1080
#   http://user:pass@proxy.example:3128
#   https://proxy.example:8443
TELEGRAM_PROXY_URL=

# Origin that is allowed to POST /submit (your production URL).
# Leave empty in development to allow same-origin requests only.
ALLOWED_ORIGIN=https://renata-fizika.ru

# Port the server listens on.
PORT=3000

# Set to '1' if behind nginx / a load balancer so rate-limiting sees real IPs.
TRUST_PROXY=0

# Optional — informational only.
NODE_ENV=production
