---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Renchik.physics — репетитор по физике ЕГЭ, ОГЭ',
  description = 'Репетитор по физике: подготовка к ЕГЭ, ОГЭ и школьной программе. Мини-группы и индивидуальные занятия, понятное объяснение физики и подготовка к экзаменам.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;500;600;700;800&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div class="cosmos" aria-hidden="true"></div>
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="shooting-stars" aria-hidden="true"></div>

  <slot />

  <CookieBanner />

  <script src="/scripts/main.js" is:inline></script>
</body>
</html>
