      </div>
      <div class="h-card h-card-2">
        <div class="k">формула</div>
        <div class="v">E = mc²</div>
      </div>
      <div class="h-card h-card-3">
        <div class="k">квант</div>
        <div class="v">ℏω</div>
      </div>
