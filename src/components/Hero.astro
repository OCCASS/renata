<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <div class="hero-eyebrow reveal r-1">
        <span class="badge"><span class="badge-dot"></span>ЕГЭ · ОГЭ · школьная физика</span>
      </div>
      <h1 class="reveal r-2">
        Физика — это <span class="em">язык,</span><br>
        на котором написана <span class="underline">Вселенная.</span>
      </h1>
      <p class="hero-sub reveal r-3">
        Помогаю разобраться в механике, полях, волнах и квантах так, чтобы физика стала понятной системой, а не набором страшных формул. ЕГЭ, ОГЭ и школьная программа — онлайн и офлайн.
      </p>
      <div class="hero-ctas reveal r-4">
        <a href="#contact" class="btn btn-primary">
          Записаться на пробное
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#formats" class="btn btn-ghost">Выбрать формат</a>
      </div>
      <div class="stats reveal r-5">
        <div>
          <div class="stat-num">98 <span style="font-size: 0.5em; color: var(--ink-dim)">/ 100</span></div>
          <div class="stat-lbl">баллов ЕГЭ</div>
        </div>
        <div>
          <div class="stat-num">МГУ</div>
          <div class="stat-lbl">физфак · стипендиат</div>
        </div>
        <div>
          <div class="stat-num">№131</div>
          <div class="stat-lbl">физмат лицей · золото</div>
        </div>
      </div>
    </div>

    <!-- Hero scene -->
    <div class="hero-scene" aria-hidden="true">
